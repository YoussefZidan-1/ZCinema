}

.trending ul li img {
  @apply w-[127px] h-[163px] rounded-lg object-cover -ml-3.5;
  aspect-ratio: 127/163;
  flex-shrink: 0;
}

.search {
  @apply w-full bg-light-100/5 px-4 py-3 rounded-lg mt-10 max-w-3xl mx-auto border border-white/15;
  transition: box-shadow 0.35s ease, border-color 0.35s ease;
}

/* 1. Position the icon absolute and center it vertically */
.search div img {
  @apply h-5 w-5 absolute left-2 top-1/2 -translate-y-1/2;
  z-index: 10;
  /* Optional: add a slight opacity to make it look more modern */
  @apply opacity-60; 
}

.search:focus-within {
  border-color: rgba(104, 105, 255, 0.8);
  box-shadow: 0 0 30px rgba(119, 35, 255, 0.4);
  background: linear-gradient(135deg, rgba(42, 31, 124, 0.75), rgba(29, 25, 92, 0.5));
}

/* 2. Ensure the input padding-left accounts for the absolute icon */
.search input {
  @apply w-full bg-transparent py-2 pr-10 pl-10 text-base text-gray-200 placeholder-light-200 outline-none;
}

.all-movies {
  @apply space-y-9;
}

.all-movies ul {
  @apply grid grid-cols-1 gap-5 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-4;
}

.movie-card {
  @apply bg-dark-100 p-5 rounded-2xl shadow-inner shadow-light-100/10 border border-transparent;
  transition: all 0.25s ease;
}

.movie-card:hover {
  transform: scale(1.03);
  box-shadow: 0 16px 30px rgba(96, 9, 227, 0.45);
  border-color: rgba(96, 9, 227, 0.65);
  animation: borderPulse 1.3s ease-in-out infinite;
}

@keyframes borderPulse {
  0%, 100% { border-color: rgba(96, 9, 227, 0.65); }
  50% { border-color: rgba(163, 81, 255, 0.9); }
}

.movie-card img {
  @apply rounded-lg w-full aspect-[2/3] object-cover bg-dark-100;
}

.movie-card h3 {
  @apply text-white font-bold text-base line-clamp-1 mt-4;
}

.movie-card .content {
  @apply mt-2 flex flex-row items-center flex-wrap gap-2;
}

.rating {
  @apply flex flex-row items-center gap-1;
}

.rating img {
  @apply w-4 h-4 object-contain shrink-0; /* Fixed size: 16px */
}

.rating p {
  @apply font-bold text-base text-white leading-none;
}

/* ==========================================================================
   UTILITIES
   ========================================================================== */
.text-gradient {
  background: linear-gradient(90deg, #4400ff, #a27dff, #00e7ff, #28b5ff, #4400ff);
  background-size: 400% 400%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: gradientShift 6s ease infinite;
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@utility fancy-text {
  -webkit-text-stroke: 5px rgba(206, 206, 251, 0.5);
  font-size: 190px;
  font-family: "Bebas Neue", sans-serif;
  color: transparent;
}

.animate-fade-in {
  animation: fadeIn 0.6s ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes zoomIn {
  from { opacity: 0; transform: scale(0.9) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.animate-zoom-in {
  animation: zoomIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
