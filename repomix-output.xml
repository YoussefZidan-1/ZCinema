@import url("https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap");
@import url("https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap");

@import "tailwindcss";

@theme {
  --color-primary: #030014;
  --color-light-100: #cecefb;
  --color-light-200: #a8b5db;
  --color-gray-100: #9ca4ab;
  --color-dark-100: #0f0d23;
  --font-dm-sans: DM Sans, sans-serif, Arial;
  --breakpoint-xs: 480px;
  --background-image-hero-pattern: url("/hero-bg.webp");
}

@layer base {
  body {
    font-family: "DM Sans", serif;
    font-optical-sizing: auto;
    background: #030014;
  }

  h1 {
    @apply mx-auto max-w-4xl text-center text-5xl font-bold leading-tight tracking-[-1%] text-white sm:text-[64px] sm:leading-[76px];
  }

  h2 {
    @apply text-2xl font-bold text-white sm:text-3xl;
  }

  main {
    @apply min-h-screen relative bg-primary;
  }

  header {
    @apply sm:mt-10 mt-5;
  }

  header img {
    @apply w-full max-w-lg h-auto object-contain mx-auto drop-shadow-md;
  }
}

@layer components {
  .pattern {
    @apply bg-hero-pattern w-full h-screen bg-center bg-cover absolute z-0;
  }

  .wrapper {
    @apply px-5 py-12 xs:p-10 max-w-7xl mx-auto flex flex-col relative z-10;
  }

  .trending {
    @apply mt-20;

    & ul {
      @apply flex flex-row overflow-y-auto gap-5 -mt-10 w-full hide-scrollbar;
    }

    & ul li {
      @apply min-w-[230px] flex flex-row items-center;
    }

    & ul li p {
      @apply fancy-text mt-[22px] text-nowrap;
    }

    & ul li img {
      @apply w-[127px] h-[163px] rounded-lg object-cover -ml-3.5;
      aspect-ratio: 127/163;
      flex-shrink: 0;
    }
  }

  .search {
    @apply w-full bg-light-100/5 px-4 py-3 rounded-lg mt-10 max-w-3xl mx-auto;
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: inset 0 0 0 0 rgba(255, 255, 255, 0);

    &:focus-within {
      border-color: rgba(104, 105, 255, 0.8);
      box-shadow: 0 0 30px rgba(119, 35, 255, 0.4);
      background: linear-gradient(135deg, rgba(42, 31, 124, 0.75), rgba(29, 25, 92, 0.5));
    }

    & div {
      @apply relative flex items-center;
    }

    & img {
      @apply absolute left-2 h-5 w-5;
    }

    & input {
      @apply w-full bg-transparent py-2 sm:pr-10 pl-10 text-base text-gray-200 placeholder-light-200 outline-hidden;
      border: 1px solid transparent;
      transition: box-shadow 0.35s ease, border-color 0.35s ease, background 0.35s ease;
      background: transparent;
    }

    & input:focus {
      outline: none;
      border-color: rgba(147, 100, 255, 0.85);
      box-shadow: 0 0 20px rgba(147, 100, 255, 0.35);
      background: rgba(255, 255, 255, 0.08);
    }

    &:not(:focus-within) {
      border-color: rgba(255, 255, 255, 0.15);
      box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.25);
      background: rgba(255, 255, 255, 0.02);
    }
  }

  .all-movies {
    @apply space-y-9;

    & ul {
      @apply grid grid-cols-1 gap-5 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-4;
    }
  }

  .movie-card {
    @apply bg-dark-100 p-5 rounded-2xl shadow-inner shadow-light-100/10;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
    transform-origin: center;
    border: 1px solid rgba(96, 9, 227, 0);

    &:hover {
      transform: scale(1.03);
      box-shadow: 0 16px 30px rgba(96, 9, 227, 0.45);
      border-color: rgba(96, 9, 227, 0.65);
      animation: borderPulse 1.3s ease-in-out infinite;
    }

    &:not(:hover) {
      animation: none;
      border-color: rgba(96, 9, 227, 0);
      box-shadow: 0 12px 18px rgba(0, 0, 0, 0.2);
    }

    & img {
      @apply rounded-lg w-full;
      aspect-ratio: 2/3;
      object-fit: cover;
      background-color: #0f0d23;
    }

    & h3 {
      @apply text-white font-bold text-base line-clamp-1;
    }

    & .content {
      @apply mt-2 flex flex-row items-center flex-wrap gap-2;
    }

    & .rating {
      @apply flex flex-row items-center gap-1;
    }

    & .rating img {
      @apply size-4 object-contain;
    }

    & .rating p {
      @apply font-bold text-base text-white;
    }

    & .content span {
      @apply text-sm text-gray-100;
    }

    & .content .lang {
      @apply capitalize text-gray-100 font-medium text-base;
    }

    & .content .year {
      @apply text-gray-100 font-medium text-base;
    }
  }

  @keyframes borderPulse {
    0%, 100% {
      border-color: rgba(96, 9, 227, 0.65);
      box-shadow: 0 16px 30px rgba(0, 0, 0, 0.45);
    }
    50% {
      border-color: rgba(163, 81, 255, 0.9);
      box-shadow: 0 18px 36px rgba(0, 0, 0, 0.6);
    }
  }
}

@utility text-gradient {
  background: linear-gradient(90deg, #4400ff, #a27dff, #00e7ff, #28b5ff, #4400ff);
  background-size: 400% 400%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  animation: gradientShift 6s ease infinite;
}

.text-gradient:hover {
  animation-play-state: paused;
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@utility fancy-text {
  -webkit-text-stroke: 5px rgba(206, 206, 251, 0.5);
  font-size: 190px;
  font-family: "Bebas Neue", sans-serif;
}

@utility hide-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;

  &::-webkit-scrollbar {
    display: none;
  }
}
